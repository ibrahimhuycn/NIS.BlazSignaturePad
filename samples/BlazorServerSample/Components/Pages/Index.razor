@page "/"
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>SignaturePad Demo</PageTitle>

<div style="display:flex;flex-direction:column;gap:1rem;">
    <div style="border:1px solid #ccc;width:100%;height:300px;">
        <SignaturePad @ref="_pad" Id="signature-pad-demo" Options="_options" style="width:100%;height:100%;" OnEndStroke="OnEndStroke" />
    </div>
    <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
        <button class="btn btn-secondary" @onclick="Clear">Clear</button>
        <button class="btn btn-secondary" @onclick="Undo">Undo</button>
        <button class="btn btn-secondary" @onclick="Redo">Redo</button>
        <button class="btn btn-secondary" @onclick="ChangeColor">Change color</button>
        <button class="btn btn-secondary" @onclick="ChangeWidth">Change width</button>
        <button class="btn btn-secondary" @onclick="ChangeBackground">Change background</button>
        <button class="btn btn-secondary" @onclick="TransparentBackground">Transparent background</button>
        <button class="btn btn-primary" @onclick="SavePng">Save as PNG</button>
        <button class="btn btn-primary" @onclick="SaveSvg">Save as SVG</button>
    </div>
    @if (!string.IsNullOrEmpty(_status))
    {
        <div class="alert alert-info">@_status</div>
    }
</div>

@code {
    private SignaturePad _pad = null!;
    private SignaturePadOptions _options = new() { BackgroundColor = "rgb(255,255,255)" };
    private string _status = "";

    private void OnEndStroke() => _status = "";

    private async Task Clear()
    {
        await _pad.ClearAsync();
        _status = "Cleared";
    }

    private async Task Undo()
    {
        await _pad.UndoAsync();
        _status = "Undone";
    }

    private async Task Redo()
    {
        await _pad.RedoAsync();
        _status = "Redone";
    }

    private async Task ChangeColor()
    {
        var color = RandomColor();
        await _pad.SetPenColorAsync(color);
        _status = $"Color: {color}";
    }

    private async Task ChangeWidth()
    {
        var min = (float)(Random.Shared.NextDouble() * 10);
        var max = (float)(Random.Shared.NextDouble() * 10);
        await _pad.SetPenWidthAsync(Math.Min(min, max), Math.Max(min, max));
        _status = $"Width: {min:F1} - {max:F1}";
    }

    private async Task ChangeBackground()
    {
        var color = RandomColor();
        await _pad.SetBackgroundColorAsync(color);
        _status = $"Background: {color}";
    }

    private async Task TransparentBackground()
    {
        await _pad.SetBackgroundColorAsync("rgba(0,0,0,0)");
        _status = "Background: transparent";
    }

    private static string RandomColor()
    {
        var r = Random.Shared.Next(256);
        var g = Random.Shared.Next(256);
        var b = Random.Shared.Next(256);
        return $"rgb({r},{g},{b})";
    }

    private async Task SavePng()
    {
        if (await _pad.IsEmptyAsync())
        {
            _status = "Please provide a signature first.";
            return;
        }
        var bytes = await _pad.ToByteArrayAsync("image/png");
        if (bytes is not null)
        {
            await JS.InvokeVoidAsync("downloadFile", "signature.png", bytes, "image/png");
            _status = "PNG downloaded";
        }
    }

    private async Task SaveSvg()
    {
        if (await _pad.IsEmptyAsync())
        {
            _status = "Please provide a signature first.";
            return;
        }
        var bytes = await _pad.ToByteArrayAsync("image/svg+xml");
        if (bytes is not null)
        {
            await JS.InvokeVoidAsync("downloadFile", "signature.svg", bytes, "image/svg+xml");
            _status = "SVG downloaded";
        }
    }
}
